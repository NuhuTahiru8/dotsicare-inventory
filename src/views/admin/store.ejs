<%- include("../partials/head", { title: "Website Manager" }) %>
<%- include("../partials/nav") %>

<div class="row">
  <div>
    <h1>Website Manager</h1>
    <div class="muted">Post products to the public online store. Prices stay hidden.</div>
  </div>
  <div class="row-actions">
    <a class="btn secondary" href="/" target="_blank" rel="noopener">View Website</a>
    <a class="btn secondary" href="/dashboard">Back to Dashboard</a>
  </div>
</div>

<% if (message) { %>
  <div class="panel"><span class="pill ok"><%= message %></span></div>
<% } %>

<% if (error) { %>
  <div class="alert"><%= error %></div>
<% } %>

<div class="split">
  <div class="panel">
    <h2>Post Product</h2>
    <form class="form" method="post" action="/admin/store">
      <div class="grid">
        <label>
          Product Name *
          <input name="title" value="<%= form.title || "" %>" placeholder="Apple iPhone 15 Pro Max" required />
        </label>
        <label>
          Category *
          <select name="category" required>
            <% for (const category of categories) { %>
              <option value="<%= category %>" <%= form.category === category ? "selected" : "" %>><%= category %></option>
            <% } %>
          </select>
        </label>
        <label>
          WhatsApp Number
          <input name="whatsapp_phone" value="<%= form.whatsapp_phone || "" %>" placeholder="233XXXXXXXXX" />
        </label>
        <label class="span-2">
          Specs
          <textarea name="specs" rows="4" placeholder="256GB&#10;Battery health 91%&#10;Factory unlocked"><%= form.specs || "" %></textarea>
        </label>
        <label class="span-2">
          Product Info
          <textarea name="description" rows="4" placeholder="Clean condition, original display, comes with warranty..."><%= form.description || "" %></textarea>
        </label>
        <label class="span-2">
          Images
          <div class="upload-zone" id="uploadZone">
            <div class="upload-zone-hint">
              <span class="upload-icon">&#xe287;</span>
              <strong>Drop images here</strong>
              <span class="muted">or click to browse &middot; JPG, PNG, WebP, GIF &middot; max 20MB each</span>
            </div>
            <input type="file" name="images" accept="image/*" multiple hidden id="uploadInput" />
          </div>
          <div class="upload-preview-grid" id="uploadPreview"></div>
        </label>
        <label class="span-2">
          Image Links *
          <textarea name="image_urls" id="imageUrlsField" rows="4" placeholder="&#10;Paste image links, one per line — or upload images above and they'll appear here automatically." required><%= form.image_urls || "" %></textarea>
        </label>
      </div>
      <div class="form-footer">
        <label class="inline">
          <input name="featured" type="checkbox" <%= form.featured ? "checked" : "" %> />
          Best seller
        </label>
        <label class="inline">
          <input name="active" type="checkbox" <%= form.active ? "checked" : "" %> />
          Show on website
        </label>
      </div>
      <button class="btn" type="submit">Publish Product</button>
    </form>
  </div>

  <div class="panel">
    <h2>Published Products</h2>
    <table class="table compact">
      <thead>
        <tr>
          <th>Photo</th>
          <th>Product</th>
          <th>Category</th>
          <th>Status</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% for (const item of listings) { %>
          <tr>
            <td><img class="mini-thumb" src="<%= item.first_image %>" alt="<%= item.title %>" /></td>
            <td>
              <strong><%= item.title %></strong>
              <div class="muted"><%= item.branch %> · <a href="/store/<%= item.slug %>" target="_blank" rel="noopener">Open</a></div>
            </td>
            <td><%= item.category %></td>
            <td><span class="pill <%= item.active ? "ok" : "muted" %>"><%= item.active ? "Live" : "Hidden" %></span></td>
            <td>
              <div class="table-actions">
                <a class="btn small secondary" href="/admin/store/<%= item.id %>/edit">Edit</a>
                <form method="post" action="/admin/store/<%= item.id %>/toggle">
                  <button class="btn small secondary" type="submit"><%= item.active ? "Hide" : "Show" %></button>
                </form>
                <form method="post" action="/admin/store/<%= item.id %>/delete" onsubmit="return confirm('Delete this website post?');">
                  <button class="btn small danger" type="submit">Delete</button>
                </form>
              </div>
            </td>
          </tr>
        <% } %>
        <% if (listings.length === 0) { %>
          <tr>
            <td colspan="5" class="muted">No public products posted yet.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<script>
(function () {
  var uploadZone = document.getElementById("uploadZone");
  var uploadInput = document.getElementById("uploadInput");
  var imageUrlsField = document.getElementById("imageUrlsField");
  var previewGrid = document.getElementById("uploadPreview");

  if (!uploadZone || !uploadInput || !imageUrlsField) return;

  uploadZone.addEventListener("click", function () { uploadInput.click(); });

  uploadZone.addEventListener("dragover", function (e) { e.preventDefault(); uploadZone.classList.add("drag-over"); });
  uploadZone.addEventListener("dragleave", function () { uploadZone.classList.remove("drag-over"); });
  uploadZone.addEventListener("drop", function (e) {
    e.preventDefault();
    uploadZone.classList.remove("drag-over");
    handleFiles(e.dataTransfer.files);
  });

  uploadInput.addEventListener("change", function () { handleFiles(uploadInput.files); uploadInput.value = ""; });

  function handleFiles(files) {
    var formData = new FormData();
    for (var i = 0; i < files.length; i++) {
      formData.append("images", files[i]);
    }
    uploadZone.querySelector(".upload-zone-hint").innerHTML = '<strong>Uploading...</strong>';
    fetch("/admin/store/upload", { method: "POST", body: formData })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        var current = imageUrlsField.value.trim();
        var lines = current ? current.split("\n").filter(Boolean) : [];
        var newLines = lines.concat(data.urls);
        imageUrlsField.value = newLines.join("\n");
        renderPreviews(newLines);
        uploadZone.querySelector(".upload-zone-hint").innerHTML =
          '<span class="upload-icon">&#xe287;</span><strong>Drop images here</strong><span class="muted">or click to browse &middot; JPG, PNG, WebP, GIF &middot; max 20MB each</span>';
      })
      .catch(function () {
        uploadZone.querySelector(".upload-zone-hint").innerHTML =
          '<span class="upload-icon">&#xe287;</span><strong>Upload failed</strong><span class="muted">try again</span>';
      });
  }

  function renderPreviews(urls) {
    previewGrid.innerHTML = "";
    urls.forEach(function (url) {
      var img = document.createElement("img");
      img.src = url;
      img.alt = "Preview";
      img.className = "upload-preview-thumb";
      previewGrid.appendChild(img);
    });
  }

  imageUrlsField.addEventListener("input", function () {
    var lines = imageUrlsField.value.trim().split("\n").filter(Boolean);
    renderPreviews(lines);
  });

  // initial render
  renderPreviews(imageUrlsField.value.trim().split("\n").filter(Boolean));
})();
</script>

<%- include("../partials/foot") %>
