<%- include("../partials/head", { title: "SMS Templates" }) %>
<%- include("../partials/nav") %>

<div class="row">
  <h1>SMS Templates</h1>
  <a class="btn secondary" href="/sms">Back</a>
</div>

<table class="table">
  <thead>
    <tr>
      <th>ID</th>
      <th>Name</th>
      <th>Body</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% for (const t of templates) { %>
      <tr>
        <td><%= t.id %></td>
        <td><%= t.name %></td>
        <td class="mono"><%= t.body %></td>
        <td>
          <a class="btn small" href="/sms?template_id=<%= t.id %>">Use</a>
          <form method="post" action="/sms/templates/<%= t.id %>/delete" style="display:inline" onsubmit="return confirm('Delete this template?')">
            <button class="btn small danger" type="submit">Delete</button>
          </form>
        </td>
      </tr>
    <% } %>
    <% if (templates.length === 0) { %>
      <tr>
        <td colspan="4" style="text-align:center;padding:40px;color:#9ca3af;">No SMS templates yet. Create them from the SMS Center page.</td>
      </tr>
    <% } %>
  </tbody>
</table>

<%- include("../partials/foot") %>
