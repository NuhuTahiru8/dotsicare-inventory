<%- include("../partials/head", { title: "SMS Center" }) %>
<%- include("../partials/nav") %>

<div class="row">
  <h1>SMS Center</h1>
  <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;">
    <div style="background:#f0f9ff;border:1px solid #bae6fd;border-radius:8px;padding:8px 16px;font-size:14px;">
      <span style="color:#0369a1;">SMS Credits: <strong><%= locals.smsCredits || 0 %></strong></span>
    </div>
    <% if ((locals.smsCredits || 0) < 10) { %>
    <a href="/credits" style="background:#2563eb;color:#fff;padding:8px 16px;border-radius:8px;text-decoration:none;font-size:14px;">Buy Credits</a>
    <% } else { %>
    <a href="/credits" style="color:#2563eb;text-decoration:none;font-size:14px;">Top Up</a>
    <% } %>
  </div>
  <div class="row-actions">
    <a class="btn secondary" href="/sms/templates">Templates</a>
    <a class="btn secondary" href="/sms/logs">Logs</a>
  </div>
</div>

<% if (error) { %>
  <div class="alert"><%= error %></div>
<% } %>



<form class="form" method="post" action="/sms/send" id="smsForm">
  <input type="hidden" name="view" value="<%= locals.view || 'installment' %>" />
  <div class="grid">
    <label>
      Sender ID
      <input readonly value="<%= senderId %>" class="mono" />
    </label>

    <label class="span-2">
      Message *
      <textarea name="message" id="msgText" rows="4" required placeholder="Type the SMS message"><%= message || "" %></textarea>
    </label>

    <% if (templates.length > 0) { %>
      <div class="span-2" style="margin-top: -4px;">
        <span class="muted" style="font-size: 12px; display: block; margin-bottom: 6px;">Click a template to fill the message:</span>
        <div style="display: flex; flex-wrap: wrap; gap: 6px;">
          <% for (const t of templates) { %>
            <button type="button" class="btn secondary small" style="font-size: 12px; padding: 4px 10px;" onclick="fillTemplate('<%= t.body.replace(/'/g, "\\'").replace(/\n/g, "\\n") %>')" title="<%= t.body.replace(/"/g, '&quot;') %>"><%= t.name %></button>
          <% } %>
        </div>
      </div>
    <% } %>
  </div>

  <!--  PASTE CONTACTS  -->
  <div class="panel" style="border: 2px solid var(--blue); background: rgba(0,122,255,0.03);">
    <div class="row">
      <h2>Paste Contacts</h2>
      <div class="muted">Paste any text with phone numbers &mdash; only Ghana numbers are kept.</div>
    </div>
    <label class="span-2">
      <textarea id="pasteArea" rows="6" placeholder="Paste contacts from your phone here...&#10;&#10;e.g.&#10;Mom: 0244123456&#10;Dad: +233501234567&#10;Kwame 0205551234&#10;+44123456789 (will be removed)&#10;0541234567&#10;etc..." style="font-family: monospace; font-size: 13px;"></textarea>
    </label>
    <div class="form-footer">
      <button class="btn secondary" type="button" id="sanitizeBtn">Sanitize &amp; Preview</button>
      <span class="muted" id="sanitizeCount" style="margin-left: 12px;"></span>
    </div>
    <div id="pastePreview" style="display: none; margin-top: 12px; max-height: 180px; overflow-y: auto;">
      <table class="table compact" id="pastePreviewTable">
        <thead>
          <tr>
            <th><input type="checkbox" id="selectAllPaste" /></th>
            <th>#</th>
            <th>Phone</th>
            <th>Source Text</th>
          </tr>
        </thead>
        <tbody id="pastePreviewBody"></tbody>
      </table>
      <div class="form-footer">
        <button class="btn" type="submit" id="sendPasteBtn" disabled>Send to <span id="sendPasteCount">0</span> Contact(s)</button>
      </div>
    </div>
    <div class="hint" style="margin-top: 8px;">Numbers that start with <strong>233</strong>, <strong>05</strong>, <strong>02</strong>, <strong>05</strong>, <strong>054</strong>, <strong>055</strong>, <strong>059</strong>, <strong>026</strong>, <strong>027</strong>, <strong>024</strong>, <strong>020</strong> are kept. Foreign numbers are removed. Duplicates are merged.</div>
  </div>

  <!--  CUSTOMERS TABLE  -->
  <div class="panel">
    <div class="row">
      <h2><%= (locals.view === "all") ? "All Customers" : (locals.view === "birthday") ? "Birthday Customers 🎂" : (locals.view === "manual") ? "Manual Contacts 📋" : "Installment Customers" %> (<%= recipients.length %>)</h2>
      <div class="row-actions">
        <label>
          View
          <select name="viewSelect" onchange="location.href='/sms?view='+encodeURIComponent(this.value)+'&filter='+encodeURIComponent('<%= locals.filter || "overdue" %>')">
            <option value="installment" <%= locals.view === "installment" ? "selected" : "" %>>Installment Customers</option>
            <option value="all" <%= locals.view === "all" ? "selected" : "" %>>All Customers</option>
            <option value="birthday" <%= locals.view === "birthday" ? "selected" : "" %>>Birthday 🎂</option>
            <option value="manual" <%= locals.view === "manual" ? "selected" : "" %>>Manual Contacts 📋</option>
          </select>
        </label>
        <% if (locals.view === "installment") { %>
        <label>
          Filter
          <select name="filter" onchange="location.href='/sms?view=installment&filter='+encodeURIComponent(this.value)">
            <option value="overdue" <%= filter === "overdue" ? "selected" : "" %>>Overdue</option>
            <option value="due-soon" <%= filter === "due-soon" ? "selected" : "" %>>Due Soon</option>
            <option value="all-active" <%= filter === "all-active" ? "selected" : "" %>>All Active</option>
          </select>
        </label>
        <% } %>
      </div>
    </div>

    <% if (locals.view === "birthday") { %>
    <table class="table compact">
      <thead>
        <tr>
          <th><input type="checkbox" id="selectAllCustomers" /></th>
          <th>Customer</th>
          <th>Phone</th>
          <th>Birthday</th>
        </tr>
      </thead>
      <tbody>
        <% for (const r of recipients) { %>
          <tr>
            <td><input type="checkbox" name="recipient" value="<%= r.id %>" class="customer-check" checked /></td>
            <td><strong><%= r.name %></strong> 🎈</td>
            <td class="mono"><%= r.phone %></td>
            <td><%= r.birth_day %> <%= r.birth_month %></td>
          </tr>
        <% } %>
      </tbody>
    </table>
    <% if (recipients.length === 0) { %>
      <p style="text-align:center;color:#9ca3af;padding:20px;">No customers celebrating their birthday today.</p>
    <% } %>
    <% } else if (locals.view === "all") { %>
    <table class="table compact">
      <thead>
        <tr>
          <th><input type="checkbox" id="selectAllCustomers" /></th>
          <th>Customer</th>
          <th>Phone</th>
        </tr>
      </thead>
      <tbody>
        <% for (const r of recipients) { %>
          <tr>
            <td><input type="checkbox" name="recipient" value="<%= r.id %>" class="customer-check" /></td>
            <td><%= r.name %></td>
            <td class="mono"><%= r.phone %></td>
          </tr>
        <% } %>
      </tbody>
    </table>
    <% if (recipients.length === 0) { %>
      <p style="text-align:center;color:#9ca3af;padding:20px;">No customers found.</p>
    <% } %>
    <% } else if (locals.view === "manual") { %>
    <table class="table compact">
      <thead>
        <tr>
          <th><input type="checkbox" id="selectAllCustomers" /></th>
          <th>Phone</th>
          <th>Name</th>
          <th>Source</th>
          <th>Added</th>
        </tr>
      </thead>
      <tbody>
        <% for (const r of recipients) { %>
          <tr>
            <td><input type="checkbox" name="recipient" value="<%= r.id %>" class="customer-check" checked /></td>
            <td class="mono"><%= r.phone %></td>
            <td><%= r.name || '-' %></td>
            <td class="muted" style="font-size:12px;"><%= (r.source_text || '').slice(0, 40) %></td>
            <td class="muted" style="font-size:12px;"><%= (r.created_at || '').slice(0, 10) %></td>
          </tr>
        <% } %>
      </tbody>
    </table>
    <% if (recipients.length === 0) { %>
      <p style="text-align:center;color:#9ca3af;padding:20px;">No manual contacts saved yet. When you send SMS to numbers that are not customers, they'll appear here.</p>
    <% } %>
    <% } else { %>
    <table class="table compact">
      <thead>
        <tr>
          <th><input type="checkbox" id="selectAllCustomers" /></th>
          <th>Customer</th>
          <th>Phone</th>
          <th>Invoice</th>
          <th>Balance</th>
          <th>Due</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% for (const r of recipients) { %>
          <tr>
            <td><input type="checkbox" name="recipient" value="<%= r.sale_id %>" class="customer-check" /></td>
            <td><%= r.name %></td>
            <td class="mono"><%= r.phone %></td>
            <td class="mono"><%= r.invoice_no %></td>
            <td>&#8373; <%= r.balance %></td>
            <td><%= r.due_date_short %></td>
            <td><span class="pill <%= r.status === "Overdue" ? "danger" : "warn" %>"><%= r.status %></span></td>
          </tr>
        <% } %>
      </tbody>
    </table>
    <% if (recipients.length === 0) { %>
      <p style="text-align:center;color:#9ca3af;padding:20px;">No installment customers found for this filter.</p>
    <% } %>
    <% } %>
  </div>

  <div class="panel">
    <div class="grid">
      <label>
        <span class="inline">
          <input type="checkbox" name="save_as_template" />
          Save as template
        </span>
      </label>
      <label>
        Template Name
        <input name="template_name" placeholder="e.g. Birthday Wish, Promo Blast" />
      </label>
    </div>
  </div>

  <button class="btn" type="submit" id="submitSms">Send SMS</button>
</form>

<script>
function fillTemplate(body) {
  document.getElementById("msgText").value = body;
}

//  Paste area logic
(function () {
  var pasteArea = document.getElementById("pasteArea");
  var sanitizeBtn = document.getElementById("sanitizeBtn");
  var sanitizeCount = document.getElementById("sanitizeCount");
  var previewDiv = document.getElementById("pastePreview");
  var previewBody = document.getElementById("pastePreviewBody");
  var selectAllPaste = document.getElementById("selectAllPaste");
  var sendPasteBtn = document.getElementById("sendPasteBtn");
  var sendPasteCount = document.getElementById("sendPasteCount");

  var pasteNumbers = [];

  function extractGhanaNumbers(text) {
    return text.match(/(?:\+?233|0)(?:20|24|26|27|28|50|53|54|55|56|57|59)\d{7}/g) || [];
  }

  function cleanNumber(raw) {
    var n = raw.trim().replace(/^\+/, "");
    if (n.startsWith("0")) n = "233" + n.slice(1);
    return n;
  }

  sanitizeBtn.addEventListener("click", function () {
    var raw = pasteArea.value || "";
    var matches = extractGhanaNumbers(raw);
    var seen = new Set();
    pasteNumbers = [];
    for (var i = 0; i < matches.length; i++) {
      var clean = cleanNumber(matches[i]);
      if (!seen.has(clean)) {
        seen.add(clean);
        pasteNumbers.push({ phone: clean, source: matches[i] });
      }
    }

    sanitizeCount.textContent = pasteNumbers.length + " Ghana number(s) found";
    previewBody.innerHTML = "";

    if (pasteNumbers.length === 0) {
      previewDiv.style.display = "none";
      return;
    }

    previewDiv.style.display = "block";
    for (var j = 0; j < pasteNumbers.length; j++) {
      var tr = document.createElement("tr");
      tr.innerHTML =
        '<td><input type="checkbox" name="paste_recipient" value="' + pasteNumbers[j].phone + '" class="paste-check" checked /></td>' +
        '<td>' + (j + 1) + '</td>' +
        '<td class="mono">' + pasteNumbers[j].phone + '</td>' +
        '<td class="muted" style="font-size:12px;">' + pasteNumbers[j].source + '</td>';
      previewBody.appendChild(tr);
    }

    updatePasteCount();
  });

  selectAllPaste.addEventListener("change", function () {
    var checks = document.querySelectorAll(".paste-check");
    for (var i = 0; i < checks.length; i++) checks[i].checked = selectAllPaste.checked;
    updatePasteCount();
  });

  previewBody.addEventListener("change", function () { updatePasteCount(); });

  function updatePasteCount() {
    var checked = document.querySelectorAll(".paste-check:checked");
    var count = checked.length;
    sendPasteCount.textContent = count;
    sendPasteBtn.disabled = count === 0;
  }

  document.getElementById("selectAllCustomers").addEventListener("change", function () {
    var checks = document.querySelectorAll(".customer-check");
    for (var i = 0; i < checks.length; i++) checks[i].checked = document.getElementById("selectAllCustomers").checked;
  });
})();
</script>

<%- include("../partials/foot") %>
