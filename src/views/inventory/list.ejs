<%- include("../partials/head", { title: "Inventory" }) %>
<%- include("../partials/nav") %>

<div class="row">
  <div>
    <h1>Inventory</h1>
    <% if (currentBranch) { %>
      <div class="muted"><%= currentBranch.name %> stock only</div>
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:8px;margin:16px 0 24px;">
    <% 
      var stockSummary = {};
      items.forEach(function(d) {
        var key = d.model + " " + (d.storage || "") + " " + (d.color || "");
        if (!stockSummary[key]) stockSummary[key] = 0;
        stockSummary[key]++;
      });
      Object.keys(stockSummary).sort().forEach(function(k) { %>
        <div style="background:#f0f9ff;border:1px solid #bae6fd;border-radius:8px;padding:8px 12px;font-size:13px;">
          <strong><%= k %></strong>: <%= stockSummary[k] %> in stock
        </div>
    <% }); %>
  </div>

    <% } %>
  </div>
  <a class="btn" href="/inventory/new">Add Stock</a>
</div>

<% if (message) { %>
  <div class="panel"><span class="pill ok"><%= message %></span></div>
<% } %>

<% if (error) { %>
  <div class="alert"><%= error %></div>
<% } %>

<table class="table">
  <thead>
    <tr>
      <th>ID</th>
      <th>Model</th>
      <th>Variant</th>
      <th>Condition</th>
      <th>IMEI(s)</th>
      <th>Status</th>
      <th>Cost</th>
      <th>Sale</th>
      <th>Added</th>
      <% if (currentUser && currentUser.role === "Admin") { %>
        <th>Actions</th>
      <% } %>
    </tr>
  </thead>
  <tbody>
    <% for (const d of items) { %>
      <tr>
        <td><%= d.first_id %></td>
        <td><%= d.model %></td>
        <td><%= [d.storage, d.color].filter(Boolean).join(" / ") %></td>
        <td><%= d.condition %></td>
        <td class="mono"><%= d.imeis || "" %></td>
        <td><span class="pill <%= d.status === "InStock" ? "ok" : "muted" %>"><%= d.status %></span></td>
        <td>&#8373; <%= currency(d.cost_price) %></td>
        <td>&#8373; <%= currency(d.sale_price) %></td>
        <td><%= (d.created_at || "").slice(0, 10) %></td>
        <% if (currentUser && currentUser.role === "Admin") { %>
          <td>
            <div class="table-actions">
              <a class="btn small secondary" href="/inventory/<%= d.first_id %>/edit">Edit</a>
              <form method="post" action="/inventory/<%= d.first_id %>/delete" onsubmit="return confirm('Delete this stock item? This cannot be undone.');">
                <button class="btn small danger" type="submit" <%= d.status !== "InStock" ? "disabled" : "" %>>Delete</button>
              </form>
            </div>
          </td>
        <% } %>
      </tr>
    <% } %>
  </tbody>
</table>

<%- include("../partials/foot") %>
