<%- include("../partials/head", { title: "Inventory" }) %>
<%- include("../partials/nav") %>

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
  <h1 style="margin:0;">Inventory</h1>
  <a class="btn btn-primary" href="/inventory/new">+ Add Stock</a>
</div>

<!-- Stock Summary -->
  <%
    var stockByModel = {};
    var totalInStock = 0;
    var totalSold = 0;
    items.forEach(function(d) {
      var key = d.model + " " + (d.storage||"");
      if (d.status === "Sold") {
        totalSold++;
      } else {
        if (!stockByModel[key]) stockByModel[key] = 0;
        stockByModel[key]++;
        totalInStock++;
      }
    });
    var modelKeys = Object.keys(stockByModel).sort();
  %>
  <div style="display:flex;gap:12px;margin-bottom:20px;flex-wrap:wrap;align-items:center;">
    <div style="background:#f0f9ff;border:1px solid #bae6fd;border-radius:10px;padding:12px 20px;text-align:center;">
      <div style="font-size:28px;font-weight:800;color:#0369a1;"><%= totalInStock %></div>
      <div style="font-size:12px;color:#0369a1;">In Stock</div>
    </div>
    <div style="background:#fef2f2;border:1px solid #fecaca;border-radius:10px;padding:12px 20px;text-align:center;">
      <div style="font-size:28px;font-weight:800;color:#dc2626;"><%= totalSold %></div>
      <div style="font-size:12px;color:#dc2626;">Sold</div>
    </div>
    <button id="toggleModelBtn" onclick="toggleModelBreakdown()" style="background:var(--primary);color:#fff;border:none;border-radius:10px;padding:12px 20px;font-size:14px;font-weight:600;cursor:pointer;transition:all .2s;">
      Total Per Model (<%= modelKeys.length %>)
    </button>
  </div>

  <div id="modelBreakdown" style="display:none;display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:8px;margin-bottom:20px;padding:16px;background:#f8fafc;border-radius:12px;border:1px solid #e5e7eb;">
    <% modelKeys.forEach(function(k) { %>
      <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 12px;background:#fff;border-radius:8px;border:1px solid #e5e7eb;">
        <span style="font-size:13px;font-weight:600;"><%= k %></span>
        <span style="font-size:16px;font-weight:800;color:var(--primary);"><%= stockByModel[k] %></span>
      </div>
    <% }); %>
    <% if (modelKeys.length === 0) { %>
      <div style="text-align:center;color:#999;grid-column:1/-1;">No stock data</div>
    <% } %>
  </div>

  <script>
    function toggleModelBreakdown() {
      var el = document.getElementById("modelBreakdown");
      var btn = document.getElementById("toggleModelBtn");
      if (el.style.display === "none" || el.style.display === "") {
        el.style.display = "grid";
        btn.textContent = "Hide Breakdown";
      } else {
        el.style.display = "none";
        btn.textContent = "Total Per Model (<%= modelKeys.length %>)";
      }
    }
  </script>

<!-- In Stock Table -->
<h2 style="color:#22c55e;margin-bottom:8px;">In Stock</h2>
<table class="data-table">
  <thead><tr>
    <th>Type</th><th>OS</th><th>Model</th><th>Storage</th><th>Color</th><th>Condition</th><th>Price</th><th>IMEI</th><th></th>
  </tr></thead>
  <tbody>
    <% var hasStock = false; %>
    <% items.forEach(function(d) { %>
      <% if (d.status !== "Sold") { hasStock = true; %>
        <tr>
          <td><span class="badge"><%= d.product_type || "-" %></span></td>
          <td><%= d.os || "-" %></td>
          <td><strong><%= d.model %></strong></td>
          <td><%= d.storage || "-" %></td>
          <td><%= d.color || "-" %></td>
          <td><%= d.condition %></td>
          <td style="white-space:nowrap;">&#8373;<%= Number(d.sale_price).toLocaleString() %></td>
          <td class="mono" style="font-size:11px;"><%= d.imeis || "-" %></td>
          <td><a class="btn small" href="/inventory/<%= d.id %>/edit">Edit</a></td>
        </tr>
      <% } %>
    <% }); %>
    <% if (!hasStock) { %>
      <tr><td colspan="9" style="text-align:center;color:#999;padding:24px;">No items in stock</td></tr>
    <% } %>
  </tbody>
</table>

<!-- Sold Table -->
<h2 style="color:#ef4444;margin-top:32px;margin-bottom:8px;">Sold</h2>
<table class="data-table">
  <thead><tr>
    <th>Model</th><th>Storage</th><th>Color</th><th>Price</th><th>IMEI</th>
  </tr></thead>
  <tbody>
    <% var hasSold = false; %>
    <% items.forEach(function(d) { %>
      <% if (d.status === "Sold") { hasSold = true; %>
        <tr style="opacity:0.7;">
          <td><%= d.model %></td>
          <td><%= d.storage || "-" %></td>
          <td><%= d.color || "-" %></td>
          <td>&#8373;<%= Number(d.sale_price).toLocaleString() %></td>
          <td class="mono" style="font-size:11px;"><%= d.imeis || "-" %></td>
        </tr>
      <% } %>
    <% }); %>
    <% if (!hasSold) { %>
      <tr><td colspan="5" style="text-align:center;color:#999;padding:24px;">No sold items</td></tr>
    <% } %>
  </tbody>
</table>

<style>
.data-table { width:100%; border-collapse:collapse; font-size:13px; }
.data-table th { text-align:left; padding:8px; border-bottom:2px solid #e5e7eb; color:#6b7280; font-weight:600; font-size:11px; text-transform:uppercase; }
.data-table td { padding:8px; border-bottom:1px solid #f3f4f6; }
.data-table tr:hover { background:#f9fafb; }
.badge { background:#eff6ff; color:#1d4ed8; padding:2px 8px; border-radius:4px; font-size:11px; font-weight:600; }
.btn.small { padding:4px 10px; font-size:12px; }
.mono { font-family:monospace; }
@media (max-width:768px) { .data-table { font-size:11px; } .data-table th, .data-table td { padding:6px 4px; } }
</style>
