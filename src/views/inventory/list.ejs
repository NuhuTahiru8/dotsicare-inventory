<%- include("../partials/head", { title: "Inventory" }) %>
<%- include("../partials/nav") %>

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
  <h1 style="margin:0;">Inventory</h1>
  <a class="btn btn-primary" href="/inventory/new">+ Add Stock</a>
</div>

<%
  var totalStock = 0, totalSold = 0;
  var catCount = { iOS:0, Android:0, Accessory:0 };
  var modelCount = {};
  var soldByModel = {};
  var allModels = {};
  
  items.forEach(function(d) {
    totalStock += d.in_stock || 0;
    totalSold += d.sold || 0;
    
    var cat = d.product_type === "Accessory" ? "Accessory" : (d.os || "Other");
    catCount[cat] = (catCount[cat] || 0) + (d.in_stock || 0);
    
    var key = d.model + " " + (d.storage||"");
    modelCount[key] = (modelCount[key] || 0) + (d.in_stock || 0);
    if (d.sold > 0) soldByModel[key] = (soldByModel[key] || 0) + d.sold;
    allModels[key] = 1;
  });
  
  var sortedModels = Object.keys(modelCount).sort();
%>

<!-- Stock Overview Cards -->
<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:24px;">
  <div style="background:#f0fdf4;border:2px solid #22c55e;border-radius:12px;padding:20px;text-align:center;">
    <div style="font-size:36px;font-weight:800;color:#15803d;"><%= totalStock %></div>
    <div style="font-size:13px;color:#16a34a;font-weight:600;">In Stock</div>
  </div>
  <div style="background:#fef2f2;border:2px solid #ef4444;border-radius:12px;padding:20px;text-align:center;">
    <div style="font-size:36px;font-weight:800;color:#b91c1c;"><%= totalSold %></div>
    <div style="font-size:13px;color:#dc2626;font-weight:600;">Sold</div>
  </div>
  <div style="background:#eff6ff;border:2px solid #3b82f6;border-radius:12px;padding:20px;text-align:center;">
    <div style="font-size:14px;color:#1d4ed8;margin-bottom:6px;font-weight:600;">By Type</div>
    <div style="font-size:13px;color:#1e40af;line-height:1.8;">
      iOS: <strong><%= catCount.iOS||0 %></strong><br>
      Android: <strong><%= catCount.Android||0 %></strong><br>
      Acc: <strong><%= catCount.Accessory||0 %></strong>
    </div>
  </div>
  <div style="background:#f8fafc;border:2px solid #64748b;border-radius:12px;padding:20px;text-align:center;">
    <div style="font-size:14px;color:#475569;margin-bottom:6px;font-weight:600;">Models</div>
    <div style="font-size:28px;font-weight:800;color:#0f2d62;"><%= sortedModels.length %></div>
  </div>
</div>

<!-- Per Model Breakdown -->
<div style="margin-bottom:16px;">
  <h3 style="color:#0f2d62;font-size:16px;margin-bottom:8px;">Per Model</h3>
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:6px;">
    <% sortedModels.forEach(function(k) { %>
      <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 12px;background:#f9fafb;border-radius:8px;font-size:13px;border:1px solid #e5e7eb;">
        <span style="font-weight:600;"><%= k %></span>
        <span style="font-weight:800;color:#0f2d62;"><%= modelCount[k] %> <% if (soldByModel[k] > 0) { %><span style="font-size:10px;color:#ef4444;font-weight:400;"> -<%= soldByModel[k] %></span><% } %></span>
      </div>
    <% }); %>
  </div>
</div>

<!-- Clean Table -->
<table style="width:100%;border-collapse:collapse;font-size:14px;">
  <thead>
    <tr style="border-bottom:2px solid #e5e7eb;">
      <th style="text-align:left;padding:10px 8px;color:#6b7280;font-size:11px;text-transform:uppercase;">Model</th>
      <th style="text-align:left;padding:10px 8px;color:#6b7280;font-size:11px;text-transform:uppercase;">Storage</th>
      <th style="text-align:center;padding:10px 8px;color:#6b7280;font-size:11px;text-transform:uppercase;">Qty</th>
      <th style="text-align:right;padding:10px 8px;color:#6b7280;font-size:11px;text-transform:uppercase;">Price</th>
    </tr>
  </thead>
  <tbody>
    <% items.forEach(function(d) { %>
      <tr style="border-bottom:1px solid #f3f4f6;">
        <td style="padding:10px 8px;">
          <span style="font-size:10px;color:#6b7280;background:#f3f4f6;padding:2px 6px;border-radius:4px;margin-right:6px;"><%= d.product_type||"-" %></span>
          <strong><%= d.model %></strong>
        </td>
        <td style="padding:10px 8px;color:#6b7280;"><%= d.storage||"-" %></td>
        <td style="padding:10px 8px;text-align:center;">
          <span style="font-weight:700;font-size:16px;color:#0f2d62;"><%= d.in_stock||0 %></span>
          <% if (d.sold > 0) { %><span style="font-size:11px;color:#ef4444;margin-left:4px;">(-<%= d.sold %>)</span><% } %>
        </td>
        <td style="padding:10px 8px;text-align:right;font-weight:600;">&#8373;<%= Number(d.sale_price||0).toLocaleString() %></td>
      </tr>
    <% }); %>
  </tbody>
</table>

<% if (items.length === 0) { %>
  <div style="text-align:center;color:#999;padding:40px;">No stock yet.</div>
<% } %>
