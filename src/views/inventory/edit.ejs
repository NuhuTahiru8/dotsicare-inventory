<%- include("../partials/head", { title: "Edit Stock" }) %>
<%- include("../partials/nav") %>

<div class="row">
  <div>
    <h1>Edit Stock</h1>
    <div class="muted">
      <%= currentBranch ? currentBranch.name + " shop" : "Current shop" %>
      &middot; ID <span class="mono"><%= item.id %></span>
    </div>
    <% if (typeof error !== 'undefined' && error) { %>
      <div style="background:#fef2f2;border:1px solid #fecaca;color:#991b1b;padding:12px 16px;border-radius:8px;margin-top:12px;font-weight:500;">
        &#x26a0;&#xfe0f; <%= error %>
      </div>
    <% } %>
  </div>
  <a class="btn secondary" href="/inventory">Back</a>
</div>

<% if (error) { %>
  <div class="alert"><%= error %></div>
<% } %>

<form class="form" method="post" action="/inventory/<%= item.id %>/edit">
  <div class="grid">
    <label>
      Model *
      <input name="model" value="<%= item.model || "" %>" required list="datalistModels" />
    </label>
    <label>
      Storage
      <input name="storage" value="<%= item.storage || "" %>" placeholder="e.g. 128GB" />
    </label>
    <label>
      Color
      <input name="color" value="<%= item.color || "" %>" placeholder="e.g. Black" />
    </label>
    <label>
      Condition *
      <select name="condition" required>
        <option value="">Select</option>
        <option <%= item.condition === "New" ? "selected" : "" %>>New</option>
        <option <%= item.condition === "Used" ? "selected" : "" %>>Used</option>
      </select>
    </label>
    <label>
      Type
      <select name="product_type">
        <option value="Phone" <%= item.product_type === "Phone" ? "selected" : "" %>>Phone</option>
        <option value="Accessory" <%= item.product_type === "Accessory" ? "selected" : "" %>>Accessory</option>
      </select>
    </label>
    <label>
      OS
      <select name="os">
        <option value="" <%= !item.os ? "selected" : "" %>>-</option>
        <option value="iOS" <%= item.os === "iOS" ? "selected" : "" %>>iOS</option>
        <option value="Android" <%= item.os === "Android" ? "selected" : "" %>>Android</option>
      </select>
    </label>
    <label>
      Cost Price (&#8373;) *
      <input name="cost_price" type="number" min="0" value="<%= item.cost_price ?? "" %>" required />
    </label>
    <label>
      Sale Price (&#8373;) *
      <input name="sale_price" type="number" min="0" value="<%= item.sale_price ?? "" %>" required />
    </label>
    <label>
      IMEI 1 *
      <input name="imei1" value="<%= item.imei1 || "" %>" required />
    </label>
    <label>
      IMEI 2
      <input name="imei2" value="<%= item.imei2 || "" %>" />
    </label>
  </div>

  <div class="form-footer" style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;">
    <div style="display:flex;align-items:center;gap:12px;">
      <button class="btn" type="submit">Save Changes</button>
      <span class="pill <%= item.status === "InStock" ? "ok" : "muted" %>"><%= item.status %></span>
    </div>
  </div>

  <datalist id="datalistModels">
    <% for (const m of models || []) { %><option value="<%= m %>"></option><% } %>
  </datalist>
</form>

<% if (item.status === "InStock") { %>
  <div style="margin-top:16px;padding:16px;border:2px solid #fecaca;border-radius:8px;background:#fff5f5;" id="deleteConfirmBox">
    <p style="color:#991b1b;font-weight:600;margin:0 0 4px;">&#x26a0;&#xfe0f; Delete this item?</p>
    <p style="color:#7f1d1d;font-size:14px;margin:0 0 8px;">Model: <strong><%= item.model %></strong> &middot; IMEI: <strong><%= item.imei1 || 'N/A' %></strong><br>This cannot be undone. Only InStock items without sales can be removed.</p>
    <form method="post" action="/inventory/<%= item.id %>/delete">
      <button class="btn small danger" type="submit">Confirm Delete</button>
    </form>
  </div>
<% } %>

<%- include("../partials/foot") %>
