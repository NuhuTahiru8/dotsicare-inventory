<%- include("../partials/head", { title, description, keywords, ogTitle, ogImage, ogType, canonical, bodyClass }) %>

<div class="store-splash" id="storeSplash">
  <img src="/public/logo.png" alt="DOT'S iCARE logo" />
  <div>DOT'S iCARE</div>
</div>

<nav class="store-top-nav">
  <a class="store-top-brand" href="/">
    <img src="/public/logo.png" alt="DOT'S iCARE" />
    <span>
      <strong>DOT'S iCARE</strong>
      <small>Konongo &middot; Ghana</small>
    </span>
  </a>
  <div class="store-top-actions">
    <% if (currentUser) { %>
      <a class="store-btn ghost" href="/dashboard">Dashboard</a>
    <% } %>
  </div>
</nav>

<!-- HERO -->
<section class="store-hero">
  <div class="store-hero-inner">
    <div class="store-hero-text">
      <h1>Discover Premium Electronics</h1>
      <p>DOT'S iCARE brings you the finest smartphones, accessories, and gadgets. Ask for the best price on WhatsApp — no price displayed, just honest deals.</p>
      <div class="store-hero-actions">
        <a class="store-btn primary" href="#shop">Browse Products</a>
        <a class="store-btn ghost" href="<%= defaultWhatsapp %>" target="_blank">Chat on WhatsApp</a>
      </div>
    </div>
    <div class="store-hero-visual">
      <div class="hero-logo-circle">
        <img src="/public/logo.png" alt="DOT'S iCARE hero" />
      </div>
    </div>
  </div>
</section>

<!-- CIRCULAR CATEGORY CAROUSEL -->
<section class="store-section" id="shop">
  <div class="store-section-header">
    <div>
      <div class="store-eyebrow">Explore</div>
      <h2>Shop by Category</h2>
    </div>
  </div>
  <div class="category-carousel">
    <% for (const category of categories) { %>
      <a class="category-circle<%= selectedCategory === category ? " active" : "" %>"
         href="/?category=<%= encodeURIComponent(category) %>">
        <div class="circle-wrap">
          <img src="/public/logo.png" alt="<%= category %>" />
        </div>
        <span><%= category %></span>
      </a>
    <% } %>
  </div>
</section>

<!-- PILL FILTERS -->
<% if (selectedCategory) { %>
<section class="store-section" style="padding-top: 0; padding-bottom: 0;">
  <div class="pill-filters">
    <a class="pill-filter" href="/">All Products</a>
    <% for (const category of categories) { %>
      <a class="pill-filter<%= selectedCategory === category ? " active" : "" %>"
         href="/?category=<%= encodeURIComponent(category) %>">
        <%= category %>
      </a>
    <% } %>
  </div>
</section>
<% } %>

<!-- PRODUCT GRID -->
<section class="store-section">
  <div class="store-section-header">
    <div>
      <div class="store-eyebrow"><%= selectedCategory ? "Browsing" : "Discover" %></div>
      <h2><%= selectedCategory ? selectedCategory : "All Products" %></h2>
    </div>
    <div class="store-section-links">
      <% if (!selectedCategory) { %>
        <div class="pill-filters" style="margin-bottom: 0;">
          <% for (const category of categories) { %>
            <a class="pill-filter" href="/?category=<%= encodeURIComponent(category) %>"><%= category %></a>
          <% } %>
        </div>
      <% } %>
    </div>
  </div>

  <% if (listings.length) { %>
    <div class="product-grid">
      <% for (const item of listings) { %>
        <div class="product-card">
          <a href="<%= item.url %>" class="product-card-image js-gallery-open"
             data-title="<%= item.title %>"
             data-images="<%= jsonAttr(item.images) %>"
             data-whatsapp="<%= item.whatsapp_url %>">
            <img src="<%= item.selected_image %>" alt="<%= item.title %>" loading="lazy" />
            <% if (item.featured) { %>
              <span class="floating-badge">Best Seller</span>
            <% } %>
          </a>
          <div class="product-card-body">
            <a class="product-card-title" href="<%= item.url %>"><%= item.title %></a>
            <span class="product-card-cat"><%= item.category %></span>
            <% if (item.specs) { %>
              <span class="product-card-specs"><%= item.specs.split("\n").slice(0, 2).join(" &middot; ") %></span>
            <% } %>
            <div class="product-card-actions">
              <a class="store-btn primary" href="<%= item.whatsapp_url %>" target="_blank" rel="noopener">
                Ask Price
              </a>
              <a class="store-btn ghost" href="<%= item.url %>">
                Details
              </a>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  <% } else { %>
    <div class="store-empty">
      <img src="/public/logo.png" alt="" />
      <h2>Nothing here yet</h2>
      <p>We're adding products soon. Check back or message us on WhatsApp.</p>
      <a class="store-btn primary" href="<%= defaultWhatsapp %>" target="_blank">Message Us</a>
    </div>
  <% } %>
</section>

<!-- LIGHTBOX -->
<div class="store-lightbox" id="storeLightbox" hidden>
  <button class="lightbox-close" type="button" aria-label="Close gallery">&times;</button>
  <div class="lightbox-card">
    <img id="lightboxImage" src="" alt="" />
    <h3 id="lightboxTitle"></h3>
    <div class="lightbox-thumbs" id="lightboxThumbs"></div>
    <a class="store-btn primary" id="lightboxWhatsapp" href="#" target="_blank" hidden>
      Ask Price on WhatsApp
    </a>
  </div>
</div>

<!-- FOOTER -->
<footer class="store-footer">
  <img src="/public/logo.png" alt="DOT'S iCARE logo" />
  <div>
    <strong>DOT'S iCARE</strong>
    <span>Best iPhone and phone shop in Konongo, Ghana.</span>
  </div>
  <a class="store-admin-trigger" href="/login">Admin</a>
</footer>

<script>
(function () {
  var splash = document.getElementById("storeSplash");
  if (splash) {
    var seen = sessionStorage.getItem("dotsicare_store_seen3");
    if (seen) {
      splash.remove();
      document.body.classList.add("page-ready");
    } else {
      sessionStorage.setItem("dotsicare_store_seen3", "1");
      setTimeout(function () {
        splash.classList.add("hide");
        document.body.classList.add("page-ready");
        setTimeout(function () { splash.remove(); }, 700);
      }, 5000);
    }
  }

  function appendImageToLink(baseUrl, imageSrc) {
    if (!baseUrl) return "";
    var absoluteSrc = new URL(imageSrc, window.location.origin).href;
    return baseUrl + encodeURIComponent("\nSelected image: " + absoluteSrc);
  }

  var lightbox = document.getElementById("storeLightbox");
  var image = document.getElementById("lightboxImage");
  var title = document.getElementById("lightboxTitle");
  var thumbs = document.getElementById("lightboxThumbs");
  var whatsapp = document.getElementById("lightboxWhatsapp");

  function openGallery(button) {
    var images = [];
    try {
      images = JSON.parse(decodeURIComponent(button.dataset.images || "%5B%5D"));
    } catch (e) { images = []; }
    if (!images.length) images = [button.querySelector("img")?.src || "/public/logo.png"];
    var itemTitle = button.dataset.title || "Product Gallery";
    var whatsappBaseUrl = button.dataset.whatsapp || "";
    title.textContent = itemTitle;
    thumbs.innerHTML = "";
    function choose(src, index) {
      image.src = src;
      image.alt = itemTitle + " image " + (index + 1);
      Array.prototype.forEach.call(thumbs.children, function (t, i) {
        t.classList.toggle("active", i === index);
      });
      if (whatsappBaseUrl) {
        whatsapp.href = appendImageToLink(whatsappBaseUrl, src);
        whatsapp.hidden = false;
      } else {
        whatsapp.hidden = true;
      }
    }
    images.forEach(function (src, index) {
      var thumb = document.createElement("button");
      thumb.type = "button";
      thumb.innerHTML = '<img src="' + src.replace(/"/g, "&quot;") + '" alt="">';
      thumb.addEventListener("click", function () { choose(src, index); });
      thumbs.appendChild(thumb);
    });
    choose(images[0], 0);
    lightbox.hidden = false;
    document.body.classList.add("lightbox-open");
  }

  document.querySelectorAll(".js-gallery-open").forEach(function (btn) {
    btn.addEventListener("click", function (e) { e.preventDefault(); openGallery(btn); });
  });
  document.querySelector(".lightbox-close")?.addEventListener("click", function () {
    lightbox.hidden = true;
    document.body.classList.remove("lightbox-open");
  });
  lightbox?.addEventListener("click", function (e) {
    if (e.target === lightbox) {
      lightbox.hidden = true;
      document.body.classList.remove("lightbox-open");
    }
  });
})();
</script>

<%- include("../partials/foot") %>
