<%- include("../partials/head", { title: "Sale Detail" }) %>
<%- include("../partials/nav") %>

<%
  const typeLabel =
    sale.sale_type === "SwapFull" ? "Swap (Full)"
    : sale.sale_type === "SwapInstallment" ? "Swap (Installment)"
    : sale.sale_type;
%>

<div class="row no-print">
  <h1>Invoice <span class="mono"><%= sale.invoice_no %></span>
    <% if (sale.is_returned) { %>
      <span class="pill danger" style="margin-left: 10px; vertical-align: middle;">Returned</span>
    <% } %>
  </h1>
  <div class="row-actions">
    <% if (!sale.is_returned) { %>
      <a class="btn warn" href="/sales/<%= sale.id %>/return">Process Return</a>
    <% } %>
    <button class="btn" onclick="window.print()">Print Receipt</button>
    <a class="btn secondary" href="/sales">Back</a>
  </div>
</div>

<% if (sale.is_returned && returnRecord) { %>
  <div class="panel return-panel no-print">
    <h2>Return Details</h2>
    <dl class="dl">
      <div><dt>Reason</dt><dd><%= returnRecord.reason %></dd></div>
      <% if (returnRecord.fault_description) { %>
        <div><dt>Fault</dt><dd><%= returnRecord.fault_description %></dd></div>
      <% } %>
      <div><dt>IMEI</dt><dd class="mono"><%= returnRecord.imei || "-" %></dd></div>
      <div><dt>Refund</dt><dd>&#8373; <%= currency(returnRecord.refund_amount) %></dd></div>
      <div><dt>Status</dt><dd><span class="pill <%= returnRecord.status === "Resolved" ? "ok" : "warn" %>"><%= returnRecord.status %></span></dd></div>
      <% if (returnRecord.notes) { %>
        <div><dt>Notes</dt><dd><%= returnRecord.notes %></dd></div>
      <% } %>
      <div><dt>Date</dt><dd><%= (returnRecord.created_at || "").slice(0, 10) %></dd></div>
      <% if (returnRecord.exchange_sale_id) { %>
        <div><dt>Exchange</dt><dd><a href="/sales/<%= returnRecord.exchange_sale_id %>" class="btn small">View Exchange Sale #<%= returnRecord.exchange_sale_id %></a></dd></div>
      <% } else { %>
        <div style="margin-top:12px;">
          <a class="btn ok" href="/sales/<%= sale.id %>/exchange">Exchange This Item</a>
        </div>
      <% } %>
    </dl>
  </div>
<% } %>

<!-- PRINTABLE RECEIPT -->
<%
  // Group identical items (model + price + discount) to save paper
  const printGroups = {};
  const printOrder = [];
  for (var pi = 0; pi < saleItems.length; pi++) {
    var psi = saleItems[pi];
    var key = psi.model + '||' + psi.unit_price + '||' + (psi.discount || 0);
    if (!printGroups[key]) {
      printGroups[key] = {
        model: psi.model,
        unit_price: psi.unit_price,
        discount: (psi.discount || 0),
        storage: psi.storage,
        color: psi.color,
        condition: psi.condition,
        qty: 0,
        imeis: []
      };
      printOrder.push(key);
    }
    printGroups[key].qty++;
    if (psi.imeis) printGroups[key].imeis.push(psi.imeis);
  }
%>
<div class="print-receipt">
  <div class="print-receipt-header">
    <strong class="print-shop-name">DOT'S iCARE</strong>
    <span>Best iPhone & Accessories, Konongo, Ghana</span>
    <span class="print-invoice">Invoice: <%= sale.invoice_no %></span>
    <span class="print-date"><%= (sale.created_at || "").slice(0, 10) %></span>
  </div>
  <hr class="print-hr" />

  <table class="print-table">
    <tr><td class="print-dt">Customer</td><td><%= sale.customer_name %> &mdash; <%= sale.customer_phone %></td></tr>
    <tr><td class="print-dt">Type</td><td><%= typeLabel %></td></tr>
    <tr><td class="print-dt">Items</td><td><%= saleItems.length %> item(s)</td></tr>
  </table>

  <strong class="print-section">Items</strong>
  <table class="print-table">
    <thead class="print-thead"><tr><th>#</th><th>Device</th><th>Qty</th><th>Details</th><th>Price</th><th>Disc</th><th>Subtotal</th></tr></thead>
    <% for (var gi = 0; gi < printOrder.length; gi++) { var si = printGroups[printOrder[gi]]; %>
      <tr>
        <td><%= gi + 1 %></td>
        <td><%= si.model %></td>
        <td><%= si.qty %></td>
        <td style="font-size:11px;"><%= [si.storage, si.color, si.condition].filter(Boolean).join(' / ') %> <%= si.imeis.length ? ' | ' + si.imeis.join(', ') : '' %></td>
        <td>&#8373; <%= currency(si.unit_price) %></td>
        <td>&#8373; <%= currency(si.discount) %></td>
        <td><strong>&#8373; <%= currency(Math.max(0, si.unit_price - si.discount) * si.qty) %></strong></td>
      </tr>
    <% } %>
    <tr><td colspan="4"></td><td>&#8373; <%= currency(sale.sale_price) %></td><td>&#8373; <%= currency(sale.discount) %></td><td><strong>&#8373; <%= currency(net) %></strong></td></tr>
  </table>

  <table class="print-table">
    <% if (tradeValue > 0) { %>
      <tr><td class="print-dt">Trade-in Value</td><td>&#8373; <%= currency(tradeValue) %></td></tr>
    <% } %>
    <tr><td class="print-dt">Payable</td><td><strong>&#8373; <%= currency(payable) %></strong></td></tr>
  </table>

  <% if (plan) { %>
    <hr class="print-hr" />
    <strong class="print-section">Installment Plan</strong>
    <table class="print-table">
      <tr><td class="print-dt">Down Payment</td><td>&#8373; <%= currency(plan.down_payment) %></td></tr>
      <tr><td class="print-dt">Balance</td><td>&#8373; <%= currency(plan.balance) %></td></tr>
      <tr><td class="print-dt">Due Date</td><td><%= (plan.due_date || "").slice(0, 10) %></td></tr>
      <tr><td class="print-dt">Status</td><td><%= plan.status %></td></tr>
    </table>
  <% } %>

  <% if (payments.length) { %>
    <hr class="print-hr" />
    <strong class="print-section">Payments</strong>
    <table class="print-table">
      <thead class="print-thead"><tr><th>Amount</th><th>Method</th><th>Date</th></tr></thead>
      <% for (const p of payments) { %>
        <tr>
          <td>&#8373; <%= currency(p.amount) %></td>
          <td><%= p.method %></td>
          <td><%= (p.paid_at || "").slice(0, 19).replace("T", " ") %></td>
        </tr>
      <% } %>
    </table>
  <% } %>

  <% if (sale.is_returned && returnRecord) { %>
    <hr class="print-hr" />
    <strong class="print-section">Return</strong>
    <table class="print-table">
      <tr><td class="print-dt">Reason</td><td><%= returnRecord.reason %></td></tr>
      <tr><td class="print-dt">IMEI</td><td class="mono"><%= returnRecord.imei || "-" %></td></tr>
      <tr><td class="print-dt">Refund</td><td>&#8373; <%= currency(returnRecord.refund_amount) %></td></tr>
      <tr><td class="print-dt">Date</td><td><%= (returnRecord.created_at || "").slice(0, 10) %></td></tr>
    </table>
    <% if (exchangeSale) { %>
      <% const exchBalance = returnRecord.refund_amount - exchangeSale.sale_price; %>
      <strong class="print-section">Exchange</strong>
      <table class="print-table">
        <tr><td class="print-dt">Device</td><td><%= exchangeSale.device_model %></td></tr>
        <tr><td class="print-dt">IMEI</td><td class="mono"><%= exchangeSale.device_imeis || "-" %></td></tr>
        <tr><td class="print-dt">Price</td><td>&#8373; <%= currency(exchangeSale.sale_price) %></td></tr>
        <tr><td class="print-dt">Invoice</td><td><%= exchangeSale.invoice_no %></td></tr>
      </table>
      <table class="print-table">
        <tr>
          <td class="print-dt">Balance</td>
          <td>
            <% if (exchBalance > 0) { %>
              Customer receives &#8373; <%= currency(exchBalance) %>
            <% } else if (exchBalance < 0) { %>
              Customer pays &#8373; <%= currency(Math.abs(exchBalance)) %>
            <% } else { %>
              Even exchange (no balance)
            <% } %>
          </td>
        </tr>
      </table>
    <% } %>
  <% } %>

  <hr class="print-hr" />
  <div class="print-footer">
    <span>Thank you for your purchase!</span>
    <span>Sold by: <%= sale.salesperson_name || "DOT'S iCARE" %></span>
  </div>
</div>

<!-- SCREEN VIEW -->
<div class="screen-only">
  <div class="panel">
    <h2>Sale</h2>
    <dl class="dl">
      <div><dt>Customer</dt><dd><%= sale.customer_name %> (<span class="mono"><%= sale.customer_phone %></span>)</dd></div>
      <div><dt>Type</dt><dd><%= typeLabel %></dd></div>
      <div><dt>Items</dt><dd><%= saleItems.length %> device(s)</dd></div>
      <div><dt>Sale Total</dt><dd>&#8373; <%= currency(sale.sale_price) %></dd></div>
      <div><dt>Discount</dt><dd>&#8373; <%= currency(sale.discount) %></dd></div>
      <div><dt>Trade-in Value</dt><dd>&#8373; <%= currency(tradeValue || 0) %></dd></div>
      <div><dt>Payable</dt><dd>&#8373; <%= currency(payable) %></dd></div>
      <div><dt>Date</dt><dd><%= (sale.created_at || "").slice(0, 10) %></dd></div>
      <div><dt>Sold By</dt><dd><%= sale.salesperson_name || "Unknown" %></dd></div>
    </dl>
  </div>

  <div class="panel">
    <h2>Items (<%= saleItems.length %>)</h2>
    <table class="table">
      <thead>
        <tr>
          <th>#</th>
          <th>Device</th>
          <th>Details</th>
          <th>Price (₵)</th>
          <th>Discount (₵)</th>
          <th>Subtotal (₵)</th>
        </tr>
      </thead>
      <tbody>
        <% for (var idx = 0; idx < saleItems.length; idx++) { var si = saleItems[idx]; %>
          <tr>
            <td><%= idx + 1 %></td>
            <td><b><%= si.model %></b></td>
            <td style="font-size:12px;color:var(--muted);"><%= [si.storage, si.color, si.condition].filter(Boolean).join(' / ') %><% if (si.imeis) { %><br><span class="mono"><%= si.imeis %></span><% } %></td>
            <td>&#8373; <%= currency(si.unit_price) %></td>
            <td><% if (si.discount > 0) { %><span style="color:#dc2626;">&#8373; <%= currency(si.discount) %></span><% } else { %>0<% } %></td>
            <td style="font-weight:600;color:#16a34a;">&#8373; <%= currency(Math.max(0, si.unit_price - (si.discount || 0))) %></td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <div class="panel">
    <h2>Installment</h2>
    <% if (plan) { %>
      <dl class="dl">
        <div><dt>Down Payment</dt><dd>&#8373; <%= currency(plan.down_payment) %></dd></div>
        <div><dt>Balance</dt><dd>&#8373; <%= currency(plan.balance) %></dd></div>
        <div><dt>Due Date</dt><dd><%= (plan.due_date || "").slice(0, 10) %></dd></div>
        <div><dt>Status</dt><dd><span class="pill <%= plan.status === "Overdue" ? "danger" : plan.status === "PaidOff" ? "ok" : "warn" %>"><%= plan.status %></span></dd></div>
      </dl>

      <form class="form-inline" method="post" action="/sales/<%= sale.id %>/payments">
        <input name="amount" type="number" min="1" placeholder="Payment amount (&#8373;)" required />
        <select name="method">
          <option>Cash</option>
          <option>MOMO</option>
          <option>Transfer</option>
          <option>POS</option>
        </select>
        <input name="reference" placeholder="Reference (optional)" />
        <button class="btn small" type="submit">Add Payment</button>
      </form>
    <% } else { %>
      <div class="muted">Not an installment sale.</div>
    <% } %>
  </div>
</div>

<% if (tradeIn) { %>
  <div class="panel">
    <h2>Trade-in</h2>
    <dl class="dl">
      <div><dt>Model</dt><dd><%= tradeIn.device_model %></dd></div>
      <div><dt>Variant</dt><dd><%= [tradeIn.storage, tradeIn.color].filter(Boolean).join(" / ") %></dd></div>
      <div><dt>Condition</dt><dd><%= tradeIn.device_condition %></dd></div>
      <div><dt>IMEI(s)</dt><dd><span class="mono"><%= tradeIn.imeis || "" %></span></dd></div>
      <div><dt>Value</dt><dd>&#8373; <%= currency(tradeIn.trade_in_value) %></dd></div>
    </dl>
  </div>
<% } %>

<div class="panel">
  <h2>Payments</h2>
  <table class="table">
    <thead>
      <tr>
        <th>ID</th>
        <th>Amount</th>
        <th>Method</th>
        <th>Reference</th>
        <th>Date</th>
      </tr>
    </thead>
    <tbody>
      <% for (const p of payments) { %>
        <tr>
          <td><%= p.id %></td>
          <td>&#8373; <%= currency(p.amount) %></td>
          <td><%= p.method %></td>
          <td class="mono"><%= p.reference || "" %></td>
          <td><%= (p.paid_at || "").slice(0, 19).replace("T", " ") %></td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>

</div><!-- /screen-only -->

<%- include("../partials/foot") %>
