<%- include("partials/head", { title: "Buy SMS Credits" }) %>
<%- include("partials/nav") %>

<div style="max-width:600px;margin:40px auto;padding:20px;">
  <div style="text-align:center;margin-bottom:20px;">
    <img src="/public/logo.png" alt="DOT'S iCARE" style="width:80px;height:80px;border-radius:16px;">
  </div>
  <h1>Buy SMS Credits</h1>
  <p style="color:#666;margin-bottom:24px;">Top up your account to continue sending SMS.</p>

  <div style="background:linear-gradient(135deg,#2563eb,#1d4ed8);color:#fff;border-radius:16px;padding:24px;margin-bottom:24px;text-align:center;">
    <div style="font-size:14px;opacity:0.9;margin-bottom:4px;">Current Balance</div>
    <div style="font-size:40px;font-weight:bold;" id="creditBalance"><%= locals.smsCredits || 0 %></div>
    <div style="font-size:14px;opacity:0.8;">SMS Credits</div>
  </div>

  <h3 style="margin-bottom:12px;">Select Plan</h3>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;" id="plans">
    <button class="plan-btn" data-amount="5" data-credits="50" style="background:#fff;border:2px solid #e5e7eb;border-radius:12px;padding:16px;cursor:pointer;text-align:center;transition:all .2s;">
      <div style="font-size:20px;font-weight:bold;color:#111;">50 SMS</div>
      <div style="color:#2563eb;font-size:14px;margin-top:4px;">GHc 5</div>
    </button>
    <button class="plan-btn" data-amount="10" data-credits="120" style="background:#fff;border:2px solid #e5e7eb;border-radius:12px;padding:16px;cursor:pointer;text-align:center;transition:all .2s;">
      <div style="font-size:20px;font-weight:bold;color:#111;">120 SMS</div>
      <div style="color:#2563eb;font-size:14px;margin-top:4px;">GHc 10</div>
    </button>
    <button class="plan-btn" data-amount="20" data-credits="260" style="background:#fff;border:2px solid #e5e7eb;border-radius:12px;padding:16px;cursor:pointer;text-align:center;transition:all .2s;">
      <div style="font-size:20px;font-weight:bold;color:#111;">260 SMS</div>
      <div style="color:#2563eb;font-size:14px;margin-top:4px;">GHc 20</div>
    </button>
    <button class="plan-btn" data-amount="50" data-credits="700" style="background:#fff;border:2px solid #e5e7eb;border-radius:12px;padding:16px;cursor:pointer;text-align:center;transition:all .2s;">
      <div style="font-size:20px;font-weight:bold;color:#111;">700 SMS</div>
      <div style="color:#2563eb;font-size:14px;margin-top:4px;">GHc 50</div>
    </button>
  </div>

  <button id="buyBtn" disabled style="width:100%;margin-top:16px;padding:16px;background:#22c55e;color:#fff;border:none;border-radius:12px;font-size:18px;font-weight:600;cursor:pointer;opacity:0.5;">Select a Plan</button>

  <div id="status" style="margin-top:12px;text-align:center;font-size:14px;"></div>
</div>

<script>
let selected = null;
document.querySelectorAll('.plan-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    document.querySelectorAll('.plan-btn').forEach(function(b) { b.style.borderColor = '#e5e7eb'; });
    btn.style.borderColor = '#2563eb';
    selected = { amount: btn.dataset.amount, credits: btn.dataset.credits };
    document.getElementById('buyBtn').disabled = false;
    document.getElementById('buyBtn').style.opacity = '1';
    document.getElementById('buyBtn').textContent = 'Pay GHc ' + selected.amount + '  (Get ' + selected.credits + ' SMS)';
  });
});

document.getElementById('buyBtn').addEventListener('click', function() {
  if (!selected) return;
  this.disabled = true;
  this.textContent = 'Processing...';
  document.getElementById('status').textContent = '';

  fetch('/api/paystack/initialize', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ amount: selected.amount, plan: selected.credits + '_sms', credits: selected.credits })
  }).then(function(r) { return r.json(); })
    .then(function(res) {
      if (res.status === 'success' && res.authorization_url) {
        window.location.href = res.authorization_url;
      } else {
        document.getElementById('status').textContent = 'Payment failed. Try again.';
        document.getElementById('buyBtn').disabled = false;
        document.getElementById('buyBtn').textContent = 'Select a Plan';
        document.getElementById('buyBtn').style.opacity = '0.5';
      }
    })
    .catch(function() {
      document.getElementById('status').textContent = 'Network error. Try again.';
    });
});

// Check for payment callback
var url = new URL(window.location.href);
var ref = url.searchParams.get('reference');
if (ref) {
  document.getElementById('status').textContent = 'Verifying payment...';
  fetch('/api/paystack/verify?reference=' + ref)
    .then(function(r) { return r.json(); })
    .then(function(res) {
      if (res.status === 'success') {
        document.getElementById('status').innerHTML = '<span style=color:#22c55e>Payment successful! ' + res.credits_added + ' credits added.</span>';
        document.getElementById('creditBalance').textContent = parseInt(document.getElementById('creditBalance').textContent) + res.credits_added;
        setTimeout(function() { window.location.href = '/credits'; }, 2000);
      } else {
        document.getElementById('status').textContent = 'Payment verification pending.';
      }
    });
}
</script>

<%- include("partials/foot") %>
