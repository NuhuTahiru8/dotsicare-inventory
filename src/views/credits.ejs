<%- include("partials/head", { title: "Buy SMS Credits" }) %>
<%- include("partials/nav") %>

<div style="max-width:500px;margin:40px auto;padding:20px;">
  <div style="text-align:center;margin-bottom:24px;">
    <img src="/public/logo.png" alt="DOT'S iCARE" style="width:80px;height:80px;border-radius:16px;">
  </div>
  <h1 style="text-align:center;">Buy SMS Credits</h1>
  <p style="text-align:center;color:#666;margin-bottom:24px;">Top up your account to send SMS to your customers.</p>

  <div style="background:linear-gradient(135deg,#2563eb,#1d4ed8);color:#fff;border-radius:16px;padding:24px;margin-bottom:24px;text-align:center;">
    <div style="font-size:14px;opacity:0.9;">Current Balance</div>
    <div style="font-size:40px;font-weight:bold;"><%= locals.smsCredits || 0 %></div>
    <div style="font-size:14px;opacity:0.8;">SMS Credits</div>
  </div>

  <a href="https://sms.ayisun.com/index.html?mode=subscription" target="_blank" 
     style="display:block;width:100%;padding:18px;background:linear-gradient(135deg,#22c55e,#16a34a);color:#fff;border:none;border-radius:16px;font-size:18px;font-weight:700;text-align:center;text-decoration:none;box-shadow:0 4px 16px rgba(34,197,94,0.4);transition:all .3s;"
     onmouseover="this.style.transform='scale(1.02)'" onmouseout="this.style.transform='scale(1)'">
    Buy Credits on Ayisun
  </a>

  <p style="text-align:center;color:#999;font-size:13px;margin-top:16px;">
    You will be redirected to our secure payment page.<br>
    Credits are shared between all your DOT'S iCARE services.
  </p>

  <div style="margin-top:24px;padding:16px;background:#f0f9ff;border:1px solid #bae6fd;border-radius:12px;">
    <h4 style="margin:0 0 8px;color:#0369a1;">Available Plans</h4>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;font-size:13px;color:#0369a1;">
      <div>50 SMS - GHS 5</div><div>120 SMS - GHS 10</div>
      <div>260 SMS - GHS 20</div><div>700 SMS - GHS 50</div>
    </div>
  </div>
</div>

<%- include("partials/foot") %>
