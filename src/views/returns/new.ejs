<%- include("../partials/head", { title: "Process Return" }) %>
<%- include("../partials/nav") %>

<div class="row">
  <h1>Process Return</h1>
  <a class="btn secondary" href="/sales/<%= sale.id %>">Back to Sale</a>
</div>

<% if (error) { %>
  <div class="alert"><%= error %></div>
<% } %>

<div class="panel">
  <dl class="dl">
    <div><dt>Invoice</dt><dd class="mono"><%= sale.invoice_no %></dd></div>
    <div><dt>Customer</dt><dd><%= sale.customer_name %> (<%= sale.customer_phone %>)
      <% if (sale.customer_type === "Dealer") { %>
        <span class="pill warn">Dealer</span>
      <% } %>
    </dd></div>
    <div><dt>Device</dt><dd><%= sale.device_model %></dd></div>
    <div><dt>IMEI(s)</dt><dd class="mono"><%= sale.device_imeis || "-" %></dd></div>
    <% if (sale.customer_type === "Dealer") { %>
      <div><dt>Ghana Card</dt><dd class="mono"><%= sale.ghana_card || "Not provided" %></dd></div>
      <div><dt>ID Held</dt><dd>
        <% if (sale.id_held) { %>
          <span class="pill warn">Yes &mdash; Ghana Card held for installment</span>
        <% } else { %>
          <span class="pill ok">No &mdash; Paid in full</span>
        <% } %>
      </dd></div>
    <% } %>
  </dl>
</div>

<form class="panel form" method="post" action="/sales/<%= sale.id %>/return">
  <div class="grid">
    <label>
      Return Reason *
      <select name="reason" required>
        <option value="">-- select --</option>
        <% const reasons = ["Faulty Speaker","Faulty Screen","Faulty Battery","Faulty Camera","Faulty Charging Port","Network Issue","Software Issue","Water Damage","Warranty Claim","Wrong Item","Customer Changed Mind","Other"]; %>
        <% for (const r of reasons) { %>
          <option value="<%= r %>" <%= (form && form.reason === r) ? 'selected' : '' %>><%= r %></option>
        <% } %>
      </select>
    </label>
    <label>
      IMEI of Returned Device
      <input name="imei" placeholder="Last 4 digits" class="mono" value="<%= (form && form.imei) || sale.device_imeis || '' %>" />
    </label>
    <label class="span-2">
      Fault Description
      <textarea name="fault_description" rows="3" placeholder="Describe what went wrong e.g. Speaker crackles at high volume, screen flickers when charging..."><%= (form && form.fault_description) || '' %></textarea>
    </label>
    <label>
      Refund Amount (&#8373;)
      <input name="refund_amount" type="number" min="0" placeholder="0" value="<%= (form && form.refund_amount) || sale.sale_price || '' %>" />
      <span class="muted">Leave 0 if no refund yet</span>
    </label>
    <label class="span-2">
      Notes
      <textarea name="notes" rows="2" placeholder="Any extra info..."><%= (form && form.notes) || '' %></textarea>
    </label>
  </div>
  <button class="btn danger" type="submit" style="margin-top: 12px;">Confirm Return</button>
  <span class="muted" style="margin-left: 12px; font-size: 13px;">
    This will mark the sale as returned, set the device to "Returned" status, and cancel any active installment plan.
  </span>
</form>

<%- include("../partials/foot") %>
